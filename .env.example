# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nouvil

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-in-production-use-a-long-random-string

# ── CORS (comma-separated allowed origins, leave empty to allow all) ──────────
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── AI (optional) ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Email (optional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Nouvil <noreply@example.com>

# ── Google Auth (optional) ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Object Storage / GCS (optional) ──────────────────────────────────────────
# GCS_BUCKET_NAME=your-bucket-name
# GCS_KEY_FILE=path/to/service-account.json

# ── Judge0 (code execution for challenges) ────────────────────────────────────
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key
